{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping openclaw-guardian /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "OpenClaw Guardian – Anthropic rate-limit proxy + session healer",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "🔴 Cooldown",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK",       "color": "green" },
                                            "1": { "text": "COOLDOWN", "color": "red"   } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 1    }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_cooldown",
        "legendFormat": "cooldown"
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "📨 Remaining Requests",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "orange", "value": 2    },
            { "color": "yellow", "value": 5    },
            { "color": "green",  "value": 10   }
          ]},
          "unit": "short",
          "min": 0
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_remaining_requests",
        "legendFormat": "remaining requests"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "🪙 Remaining Tokens",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",   "value": null   },
            { "color": "green", "value": 10000  }
          ]},
          "unit": "short",
          "min": 0
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_remaining_tokens",
        "legendFormat": "remaining tokens"
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "⏳ Queue Length",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "orange", "value": 3    },
            { "color": "red",    "value": 10   }
          ]},
          "unit": "short",
          "min": 0
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_queue_length",
        "legendFormat": "queue"
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "⚠️ At Risk (healer paused)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "OK",       "color": "green" },
              "1": { "text": "AT RISK",  "color": "orange"}
            }}
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "orange", "value": 1    }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_at_risk",
        "legendFormat": "at risk"
      }]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "📊 Rate Limit – Remaining Requests & Tokens",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "remaining tokens" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "guardian_remaining_requests",
          "legendFormat": "remaining requests"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "guardian_remaining_tokens",
          "legendFormat": "remaining tokens"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "🔄 Request Rate & Throttles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(guardian_total_requests[1m])",
          "legendFormat": "req/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(guardian_total_throttles[1m])",
          "legendFormat": "throttles/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(guardian_total_429s[1m])",
          "legendFormat": "429s/s"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "🛠 Session Healer Activity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "guardian_sessions_scanned",
          "legendFormat": "scanned"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(guardian_sessions_repaired[5m])",
          "legendFormat": "repaired (5m)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(guardian_sessions_deleted[5m])",
          "legendFormat": "deleted (5m)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(guardian_stale_locks_removed[5m])",
          "legendFormat": "stale locks (5m)"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "🌡 Cooldown & Queue History",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "cooldown" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 20 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]}
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "guardian_cooldown",
          "legendFormat": "cooldown"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "guardian_queue_length",
          "legendFormat": "queue length"
        }
      ]
    },

    {
      "id": 10,
      "type": "stat",
      "title": "📈 Total Requests (all time)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_total_requests",
        "legendFormat": "total"
      }]
    },

    {
      "id": 11,
      "type": "stat",
      "title": "🚫 Total 429s (all time)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange","value": 1    },
            { "color": "red",   "value": 5    }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_total_429s",
        "legendFormat": "429s"
      }]
    },

    {
      "id": 12,
      "type": "stat",
      "title": "🔧 Sessions Repaired (total)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_sessions_repaired",
        "legendFormat": "repaired"
      }]
    },

    {
      "id": 13,
      "type": "stat",
      "title": "🗑 Sessions Deleted (total)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "orange", "value": 1    }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "guardian_sessions_deleted",
        "legendFormat": "deleted"
      }]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["openclaw", "guardian", "anthropic"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenClaw Guardian",
  "uid": "openclaw-guardian-v1",
  "version": 1
}
