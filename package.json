{
  "name": "openclaw-guardian",
  "version": "2.0.0",
  "description": "Session healer + usage tracker for OpenClaw",
  "keywords": [
    "openclaw",
    "session-healer",
    "usage-tracker",
    "grafana",
    "prometheus",
    "loki",
    "observability",
    "llm",
    "ai-ops"
  ],
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "start":  "node bin/start.js",
    "healer": "node bin/healer.js",
    "once":   "node bin/healer.js --once",
    "usage":  "node -e \"import('./src/usage.js').then(m => m.startUsageTracker())\""
  },
  "license": "MIT",
  "author": "Josef Kvapil (https://github.com/wraithyy)",
  "repository": {
    "type": "git",
    "url": "https://github.com/wraithyy/openclaw-guardian.git"
  },
  "bugs": {
    "url": "https://github.com/wraithyy/openclaw-guardian/issues"
  },
  "homepage": "https://github.com/wraithyy/openclaw-guardian#readme",
  "bin": {
    "openclaw-guardian": "./bin/start.js"
  },
  "dependencies": {}
}
